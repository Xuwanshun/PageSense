# ── .env.example ──────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# IMPORTANT: Never commit your real .env file. It is listed in .gitignore.
# This file (.env.example) is safe to commit — it has no real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...your-key-here...

# ── Model selection ───────────────────────────────────────────────────────────
OPENAI_MODEL=gpt-4.1-mini
EMBEDDING_MODEL=text-embedding-3-small

# ── Optional: use a different OpenAI-compatible endpoint ──────────────────────
# Leave empty to use the standard OpenAI API.
OPENAI_BASE_URL=

# ── Data directories ──────────────────────────────────────────────────────────
RAW_DOCUMENTS_DIR=data/raw
PROCESSED_DOCUMENTS_DIR=data/processed
VECTORSTORE_DIR=data/embedded
PADDLE_CACHE_DIR=data/.paddlex_cache

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# "text" for local dev, "json" for CloudWatch
LOG_FORMAT=text

# ── Application mode ──────────────────────────────────────────────────────────
# "cli" → argparse CLI  |  "api" → FastAPI server
APP_MODE=cli

# ── AWS (only needed when deploying to ECS) ───────────────────────────────────
S3_BUCKET_NAME=
AWS_REGION=us-east-1

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate: python -c "import os; print(os.urandom(32).hex())"
JWT_SECRET_KEY=
DATABASE_URL=sqlite:///data/auth.db
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
# Set true on HTTPS deployments
HTTPS_ONLY=false
# Google OAuth (leave empty to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GitHub OAuth (leave empty to disable)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Pipeline tuning ───────────────────────────────────────────────────────────
PREPROCESS_CHUNK_SIZE=1800
PREPROCESS_CHUNK_OVERLAP=200
PDF_RENDER_SCALE=2.0
DEFAULT_TOP_K=4

# ── Pipeline feature flags ────────────────────────────────────────────────────
# Query enhancement: HyDE for simple queries, decomposition for complex ones.
USE_QUERY_ENHANCEMENT=true
# Hybrid retrieval: BM25 + dense vector fused via RRF.
USE_HYBRID_RETRIEVAL=true
# LLM reranker: batch-scores retrieved chunks, drops irrelevant ones.
USE_LLM_RERANKER=true
# Context compression: strips OCR noise and off-topic sentences before synthesis.
USE_CONTEXT_COMPRESSION=true
# Faithfulness check: verifies answer claims against source chunks, rewrites if needed.
USE_FAITHFULNESS_CHECK=true
# Document intelligence: title propagation, section grouping, doc-level descriptor.
USE_DOCUMENT_INTELLIGENCE=false
# Adaptive chunking: per-document chunk size chosen by the descriptor model.
USE_ADAPTIVE_CHUNKING=false
DESCRIPTOR_MODEL=gpt-4o-mini
DOC_FILTER_THRESHOLD=0.20

# ── VLM visual summaries ──────────────────────────────────────────────────────
# Enables GPT-4o / Qwen3-VL descriptions for table and figure regions.
USE_VLM_SUMMARIES=false
VLM_MODEL=gpt-4o
# Self-hosted Modal endpoint (falls back to VLM_MODEL if unreachable).
VLM_BASE_URL=
VLM_SELF_HOSTED_MODEL=qwen3-vl-rag

# ── Vector store backend ──────────────────────────────────────────────────────
# Default: built-in JSON vector store (no extra dependencies).
PREFER_CHROMA=false

# Weaviate: persistent BM25 + dense hybrid search.
# Local dev: run via docker-compose, leave WEAVIATE_API_KEY empty.
# Weaviate Cloud: set WEAVIATE_HOST to cluster URL + WEAVIATE_API_KEY to Admin key.
PREFER_WEAVIATE=false
WEAVIATE_HOST=localhost
WEAVIATE_PORT=8080
WEAVIATE_GRPC_PORT=50051
WEAVIATE_COLLECTION=RagChunk
WEAVIATE_API_KEY=
