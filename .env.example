# ── .env.example ──────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# IMPORTANT: Never commit your real .env file. It is listed in .gitignore.
# This file (.env.example) is safe to commit — it has no real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required for --index and --ask (embedding + LLM generation) ───────────────
OPENAI_API_KEY=sk-...your-key-here...

# ── Optional: use a different OpenAI-compatible endpoint ──────────────────────
# Leave empty to use the standard OpenAI API.
# Set this if you are using Azure OpenAI, a local LM Studio server, etc.
OPENAI_BASE_URL=

# ── Model selection ───────────────────────────────────────────────────────────
# Chat model used for QA synthesis and faithfulness checking.
SYNTHESIS_MODEL=gpt-4.1-mini
# Embedding model used to convert text chunks into vectors.
EMBEDDING_MODEL=text-embedding-3-small

# ── Data directories ──────────────────────────────────────────────────────────
# Where to read input PDFs from.
RAW_DOCUMENTS_DIR=data/raw
# Where to write OCR/layout/chunk artifacts (frozen preprocessing outputs).
PROCESSED_DOCUMENTS_DIR=data/processed
# Where to store the vector index (embeddings).
VECTORSTORE_DIR=data/embedded
# Where PaddleOCR/PaddleX downloads and caches its ML models.
# Point this at a Docker volume or EFS mount in production.
PADDLE_CACHE_DIR=data/.paddlex_cache

# ── Logging ───────────────────────────────────────────────────────────────────
# Log verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# Log format: "text" (human-readable, for local dev) | "json" (for CloudWatch)
# The Dockerfile sets this to "json" automatically.
LOG_FORMAT=text

# ── Vector store backend ──────────────────────────────────────────────────────
# false → use the built-in JSON vector store (default, no extra dependencies)
# true  → use ChromaDB (install chromadb first: pip install chromadb)
PREFER_CHROMA=false

# ── RAG retrieval ─────────────────────────────────────────────────────────────
# Minimum cosine similarity for a section to pass the pre-filter (Pool A).
SECTION_FILTER_THRESHOLD=0.55
# Number of block windows returned to the synthesis step.
DEFAULT_TOP_K=4
# Run a second LLM call to verify the answer is grounded in retrieved blocks.
USE_FAITHFULNESS_CHECK=true
# Skip faithfulness gate and reduce neighbor expansion from ±2 to ±1 for faster queries.
FAST_QUERY_MODE=false

# ── Pipeline tuning ───────────────────────────────────────────────────────────
# Maximum characters per text chunk during preprocessing.
PREPROCESS_CHUNK_SIZE=1800
# Overlap between consecutive chunks (so context is not lost at chunk boundaries).
PREPROCESS_CHUNK_OVERLAP=200
# PDF rendering scale (higher = sharper images for OCR, but slower and more memory).
PDF_RENDER_SCALE=3.0
