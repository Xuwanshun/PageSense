# ── .env.example ──────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# IMPORTANT: Never commit your real .env file. It is listed in .gitignore.
# This file (.env.example) is safe to commit — it has no real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required for --index and --ask (embedding + LLM generation) ───────────────
OPENAI_API_KEY=sk-...your-key-here...

# ── Optional: use a different OpenAI-compatible endpoint ──────────────────────
# Leave empty to use the standard OpenAI API.
# Set this if you are using Azure OpenAI, a local LM Studio server, etc.
OPENAI_BASE_URL=

# ── Model selection ───────────────────────────────────────────────────────────
# Chat model used for QA and specialist agents.
OPENAI_MODEL=gpt-4.1-mini
# Embedding model used to convert text chunks into vectors.
EMBEDDING_MODEL=text-embedding-3-small

# ── Data directories ──────────────────────────────────────────────────────────
# Where to read input PDFs from.
RAW_DOCUMENTS_DIR=data/raw
# Where to write OCR/layout/chunk artifacts (frozen preprocessing outputs).
PROCESSED_DOCUMENTS_DIR=data/processed
# Where to store the vector index (embeddings).
VECTORSTORE_DIR=data/embedded
# Where PaddleOCR/PaddleX downloads and caches its ML models.
# Point this at a Docker volume or EFS mount in production.
PADDLE_CACHE_DIR=data/.paddlex_cache

# ── Logging ───────────────────────────────────────────────────────────────────
# Log verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# Log format: "text" (human-readable, for local dev) | "json" (for CloudWatch)
# The Dockerfile sets this to "json" automatically.
LOG_FORMAT=text

# ── Application mode ─────────────────────────────────────────────────────────
# "cli" → use the argparse CLI (python main.py --preprocess ...)
# "api" → start the FastAPI HTTP server (python main.py --serve)
APP_MODE=cli

# ── AWS (only needed when deploying to ECS) ───────────────────────────────────
# S3 bucket for persisting processed artifacts and the vector store.
# Leave empty for local development.
S3_BUCKET_NAME=
AWS_REGION=ca-central-1

# ── Vector store backend ──────────────────────────────────────────────────────
# false → use the built-in JSON vector store (default, no extra dependencies)
# true  → use ChromaDB (install chromadb first: pip install chromadb)
PREFER_CHROMA=false

# ── Pipeline tuning ───────────────────────────────────────────────────────────
# Maximum characters per text chunk.
PREPROCESS_CHUNK_SIZE=1800
# Overlap between consecutive chunks (so context is not lost at chunk boundaries).
PREPROCESS_CHUNK_OVERLAP=200
# PDF rendering scale (higher = sharper images for OCR, but slower and more memory).
PDF_RENDER_SCALE=3.0
# Default number of retrieved chunks used to answer a question.
DEFAULT_TOP_K=4

# ── VLM visual summaries ──────────────────────────────────────────────────────
# Enable vision enrichment for table/figure regions during preprocessing.
# Costs one API call per detected visual region. Disabled by default.
USE_VLM_SUMMARIES=false
# Fallback vision model (used when self-hosted endpoint is unset or unreachable).
VLM_MODEL=gpt-4o

# ── Self-hosted VLM via HuggingFace Inference API (optional) ─────────────────
# When set, the pipeline calls your fine-tuned model first and falls back to
# VLM_MODEL (gpt-4o) automatically on any connection error or timeout.
# Leave empty to use gpt-4o exclusively.
#
# HuggingFace Inference API URL for your model:
#   https://api-inference.huggingface.co/models/<username>/<repo>/v1
# HuggingFace Dedicated Endpoint URL:
#   https://<id>.huggingface.cloud/v1
VLM_BASE_URL=
# HuggingFace API token (from huggingface.co/settings/tokens, write access)
VLM_HF_TOKEN=
# Model name your HF endpoint exposes (default "tgi" for Inference API)
VLM_SELF_HOSTED_MODEL=tgi

# ── Document intelligence ─────────────────────────────────────────────────────
# Enable title propagation, section grouping, and a document-level descriptor.
# The descriptor summary is embedded and stored in document.json for pre-filtering.
USE_DOCUMENT_INTELLIGENCE=false
# Enable per-document adaptive chunking (overrides PREPROCESS_CHUNK_SIZE/OVERLAP).
USE_ADAPTIVE_CHUNKING=false
# Lightweight model used for section and document summarization.
DESCRIPTOR_MODEL=gpt-4o-mini
# Cosine similarity threshold for doc-level pre-filtering at query time.
DOC_FILTER_THRESHOLD=0.20

# ── Auth ─────────────────────────────────────────────────────────────────────
# Required: 32-byte random hex. Generate: python -c "import os; print(os.urandom(32).hex())"
JWT_SECRET_KEY=
# SQLite locally; use postgresql://user:pass@host/db on AWS RDS
DATABASE_URL=sqlite:///data/auth.db
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
# Set true on HTTPS deployments to add Secure flag to the refresh cookie
HTTPS_ONLY=false
# Google OAuth (leave empty to disable Google sign-in)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# GitHub OAuth (leave empty to disable GitHub sign-in)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
